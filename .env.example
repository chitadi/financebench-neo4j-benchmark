# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=financebench
NEO4J_DATABASE=neo4j

# Local paths. Place FinanceBench files here; this project does not download them.
DATA_DIR=data
PDF_DIR=pdfs
RESULTS_DIR=results
QUESTIONS_FILE=data/financebench_open_source.jsonl
DOCUMENT_INFO_FILE=data/financebench_document_information.jsonl

# Chunking
CHUNK_SIZE_WORDS=850
CHUNK_OVERLAP_WORDS=120

# Retrieval
RETRIEVAL_VECTOR_K=30
RETRIEVAL_FULLTEXT_K=30
RETRIEVAL_FINAL_K=8
RETRIEVAL_NEIGHBOR_WINDOW=1

# Embeddings.
# hash = local deterministic smoke mode. openai = OpenAI-compatible /embeddings.
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=

# Answer model. Uses OpenAI-compatible /chat/completions.
# Leave LLM_API_KEY empty for retrieval-only smoke runs with extractive fallback answers.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# Optional LLM judge for answer correctness. Default heuristic is cheap and local.
JUDGE_PROVIDER=heuristic
JUDGE_MODEL=
