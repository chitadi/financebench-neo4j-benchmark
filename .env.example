# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=financebench
NEO4J_DATABASE=neo4j

# Local paths. Place FinanceBench files here; this project does not download them.
DATA_DIR=data
PDF_DIR=pdfs
RESULTS_DIR=results
QUESTIONS_FILE=data/financebench_open_source.jsonl
DOCUMENT_INFO_FILE=data/financebench_document_information.jsonl

# Chunking
CHUNK_SIZE_WORDS=850
CHUNK_OVERLAP_WORDS=120

# Retrieval
RETRIEVAL_VECTOR_K=30
RETRIEVAL_FULLTEXT_K=30
RETRIEVAL_FINAL_K=8
RETRIEVAL_NEIGHBOR_WINDOW=1

# API keys. You can either set these provider-specific keys, or use the
# generic EMBEDDING_API_KEY / LLM_API_KEY fields below.
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Embeddings.
# V1 benchmark embeddings use Qwen through OpenRouter.
EMBEDDING_PROVIDER=openrouter
EMBEDDING_DIMENSION=2560
EMBEDDING_MODEL=qwen/qwen3-embedding-4b
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=

# Answer model. Uses OpenAI-compatible /chat/completions.
# Leave LLM_API_KEY and GEMINI_API_KEY empty for extractive fallback answers after retrieval.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0

# Optional LLM judge for answer correctness. Default heuristic is cheap and local.
JUDGE_PROVIDER=heuristic
JUDGE_MODEL=gemini-2.5-flash
